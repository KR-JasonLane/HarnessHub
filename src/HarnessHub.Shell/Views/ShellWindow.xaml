<Window x:Class="HarnessHub.Shell.Views.ShellWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        mc:Ignorable="d"
        Title="HarnessHub"
        Height="720" Width="1100"
        MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Style="{StaticResource MaterialDesignWindow}"
        Background="{DynamicResource MaterialDesign.Brush.Background}">

    <DockPanel>
        <!-- StatusBar (하단) -->
        <materialDesign:ColorZone DockPanel.Dock="Bottom"
                                  Mode="PrimaryMid"
                                  Padding="8 4">
            <DockPanel>
                <StackPanel DockPanel.Dock="Right"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <materialDesign:PackIcon Kind="WhiteBalanceSunny"
                                             Width="16" Height="16"
                                             VerticalAlignment="Center"
                                             Foreground="{DynamicResource MaterialDesign.Brush.Primary.Foreground}" />
                    <ToggleButton Style="{StaticResource MaterialDesignSwitchToggleButton}"
                                  IsChecked="{Binding IsDarkTheme}"
                                  Margin="4 0"
                                  VerticalAlignment="Center" />
                    <materialDesign:PackIcon Kind="MoonWaningCrescent"
                                             Width="16" Height="16"
                                             VerticalAlignment="Center"
                                             Foreground="{DynamicResource MaterialDesign.Brush.Primary.Foreground}" />
                </StackPanel>
                <TextBlock Text="HarnessHub v0.1"
                           Style="{StaticResource MaterialDesignCaptionTextBlock}"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource MaterialDesign.Brush.Primary.Foreground}" />
            </DockPanel>
        </materialDesign:ColorZone>

        <!-- NavigationRail (좌측) -->
        <Border DockPanel.Dock="Left"
                Background="{DynamicResource MaterialDesign.Brush.Card.Background}"
                BorderBrush="{DynamicResource MaterialDesign.Brush.TextBox.HoverBackground}"
                BorderThickness="0 0 1 0">
        <ListBox SelectedIndex="{Binding SelectedNavigationIndex}"
                 HorizontalContentAlignment="Center"
                 Width="88"
                 Padding="0 12">
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem" BasedOn="{StaticResource MaterialDesign3.NavigationRailPrimaryListBoxItem}">
                    <Setter Property="MinHeight" Value="72" />
                    <Setter Property="Padding" Value="4 12" />
                    <Setter Property="Margin" Value="5" />
                </Style>
            </ListBox.ItemContainerStyle>

            <ListBoxItem Content="대시보드"
                         materialDesign:NavigationRailAssist.SelectedIcon="ViewDashboard"
                         materialDesign:NavigationRailAssist.UnselectedIcon="ViewDashboardOutline" />

            <ListBoxItem Content="탐색기"
                         materialDesign:NavigationRailAssist.SelectedIcon="FolderSearch"
                         materialDesign:NavigationRailAssist.UnselectedIcon="FolderSearchOutline" />

            <ListBoxItem Content="에디터"
                         materialDesign:NavigationRailAssist.SelectedIcon="FileEdit"
                         materialDesign:NavigationRailAssist.UnselectedIcon="FileEditOutline" />

            <ListBoxItem Content="프리셋"
                         materialDesign:NavigationRailAssist.SelectedIcon="Tune"
                         materialDesign:NavigationRailAssist.UnselectedIcon="TuneVariant" />

            <ListBoxItem Content="설정"
                         materialDesign:NavigationRailAssist.SelectedIcon="Cog"
                         materialDesign:NavigationRailAssist.UnselectedIcon="CogOutline" />
        </ListBox>
        </Border>

        <!-- Content Area (중앙) -->
        <Grid>
            <!-- 콘텐츠가 없을 때 기본 표시 -->
            <TextBlock Text="콘텐츠를 선택하세요"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Opacity="0.5">
                <TextBlock.Style>
                    <Style TargetType="TextBlock" BasedOn="{StaticResource MaterialDesignHeadline5TextBlock}">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding CurrentContent}" Value="{x:Null}">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <ContentControl Content="{Binding CurrentContent}"
                            Margin="16" />
        </Grid>
    </DockPanel>
</Window>
