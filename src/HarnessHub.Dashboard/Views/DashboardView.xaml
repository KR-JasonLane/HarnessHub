<UserControl x:Class="HarnessHub.Dashboard.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:behaviors="clr-namespace:HarnessHub.Util.Behaviors;assembly=HarnessHub.Util"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="900">

    <Grid>
        <!-- 로딩 인디케이터 -->
        <ProgressBar Style="{StaticResource MaterialDesignLinearProgressBar}"
                     IsIndeterminate="True"
                     VerticalAlignment="Top"
                     Panel.ZIndex="1"
                     Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}" />

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="8">

                <!-- 프로젝트 경로 섹션 -->
                <materialDesign:Card Padding="16" Margin="0 0 0 16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <materialDesign:PackIcon Grid.Column="0"
                                                 Kind="FolderOpen"
                                                 Width="24" Height="24"
                                                 VerticalAlignment="Center"
                                                 Margin="0 0 12 0"
                                                 Foreground="{DynamicResource MaterialDesign.Brush.Primary}" />

                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="{Binding ProjectPath, TargetNullValue='프로젝트 폴더를 선택하세요'}"
                                       Style="{StaticResource MaterialDesignBody1TextBlock}"
                                       TextTrimming="CharacterEllipsis" />
                            <TextBlock Text="{Binding GlobalPath, StringFormat='글로벌: {0}'}"
                                       Style="{StaticResource MaterialDesignCaptionTextBlock}"
                                       Opacity="0.6"
                                       Margin="0 2 0 0" />
                        </StackPanel>

                        <Button Grid.Column="2"
                                Style="{StaticResource MaterialDesignFlatButton}"
                                Command="{Binding OpenFolderCommand}"
                                Content="폴더 열기"
                                Margin="8 0" />

                        <Button Grid.Column="3"
                                Style="{StaticResource MaterialDesignIconButton}"
                                Command="{Binding RefreshCommand}"
                                ToolTip="새로고침">
                            <materialDesign:PackIcon Kind="Refresh" />
                        </Button>
                    </Grid>
                </materialDesign:Card>

                <!-- 에러 메시지 -->
                <materialDesign:Card Padding="12" Margin="0 0 0 12"
                                     Visibility="{Binding ErrorMessage, TargetNullValue=Collapsed, FallbackValue=Collapsed}">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="AlertCircle" Width="20" Height="20"
                                                 VerticalAlignment="Center" Margin="0 0 8 0" />
                        <TextBlock Text="{Binding ErrorMessage}"
                                   Style="{StaticResource MaterialDesignBody2TextBlock}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </materialDesign:Card>

                <!-- 5대 레버 상태 카드 -->
                <TextBlock Text="하네스 레버 상태"
                           Style="{StaticResource MaterialDesignHeadline6TextBlock}"
                           Margin="0 8 0 8" />

                <ItemsControl ItemsSource="{Binding LeverStatuses}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Rows="1" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <materialDesign:Card Padding="16" Margin="4">
                                <StackPanel HorizontalAlignment="Center">
                                    <materialDesign:PackIcon Width="32" Height="32"
                                                             HorizontalAlignment="Center"
                                                             Margin="0 0 0 8">
                                        <materialDesign:PackIcon.Style>
                                            <Style TargetType="materialDesign:PackIcon">
                                                <Setter Property="Kind" Value="AlertCircleOutline" />
                                                <Setter Property="Foreground" Value="{DynamicResource MaterialDesign.Brush.Foreground.Disabled}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                        <Setter Property="Kind" Value="CheckCircle" />
                                                        <Setter Property="Foreground" Value="{DynamicResource MaterialDesign.Brush.Primary}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </materialDesign:PackIcon.Style>
                                    </materialDesign:PackIcon>

                                    <TextBlock Text="{Binding Description}"
                                               Style="{StaticResource MaterialDesignSubtitle2TextBlock}"
                                               HorizontalAlignment="Center" />

                                    <TextBlock HorizontalAlignment="Center"
                                               Margin="0 4 0 0"
                                               Opacity="0.7">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock" BasedOn="{StaticResource MaterialDesignCaptionTextBlock}">
                                                <Setter Property="Text" Value="미설정" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                        <Setter Property="Text" Value="{Binding FileCount, StringFormat='{}{0}개 파일'}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </materialDesign:Card>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- 토큰 사용량 -->
                <TextBlock Text="토큰 사용량"
                           Style="{StaticResource MaterialDesignHeadline6TextBlock}"
                           Margin="0 24 0 8" />

                <materialDesign:Card Padding="16" Margin="0 0 0 16">
                    <StackPanel>
                        <DockPanel Margin="0 0 0 8">
                            <TextBlock DockPanel.Dock="Right"
                                       Style="{StaticResource MaterialDesignBody2TextBlock}">
                                <Run Text="{Binding TotalTokens, StringFormat='{}{0:N0}', Mode=OneWay}" />
                                <Run Text=" / " />
                                <Run Text="{Binding ContextWindowSize, StringFormat='{}{0:N0}', Mode=OneWay}" />
                                <Run Text=" tok" />
                            </TextBlock>
                            <TextBlock Text="{Binding UsagePercentage, StringFormat='{}{0:F1}%'}"
                                       Style="{StaticResource MaterialDesignBody2TextBlock}"
                                       Foreground="{DynamicResource MaterialDesign.Brush.Primary}" />
                        </DockPanel>
                        <ProgressBar Style="{StaticResource MaterialDesignLinearProgressBar}"
                                     Minimum="0" Maximum="100"
                                     Value="{Binding UsagePercentage, Mode=OneWay}"
                                     Height="8" />
                    </StackPanel>
                </materialDesign:Card>

                <!-- 하네스 파일 목록 -->
                <TextBlock Text="하네스 파일 목록"
                           Style="{StaticResource MaterialDesignHeadline6TextBlock}"
                           Margin="0 24 0 8" />

                <!-- 파일 없을 때 -->
                <TextBlock Text="하네스 파일이 없습니다. 프로젝트 폴더를 선택하세요.">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock" BasedOn="{StaticResource EmptyStateText}">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HarnessFiles.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <materialDesign:Card Padding="0">
                    <DataGrid ItemsSource="{Binding HarnessFiles}"
                              Style="{StaticResource HarnessDataGrid}"
                              behaviors:DataGridDoubleClickBehavior.Command="{Binding OpenFileCommand}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="파일명"
                                                Binding="{Binding FileName}"
                                                Width="*" />
                            <DataGridTextColumn Header="유형"
                                                Binding="{Binding FileType}"
                                                Width="140" />
                            <DataGridTextColumn Header="범위"
                                                Binding="{Binding Scope}"
                                                Width="80" />
                            <DataGridTextColumn Header="레버"
                                                Binding="{Binding Lever}"
                                                Width="120" />
                            <DataGridTextColumn Header="토큰"
                                                Binding="{Binding TokenCount, StringFormat='{}{0:N0}'}"
                                                Width="80">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Right" />
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="수정일"
                                                Binding="{Binding LastModified, StringFormat='{}{0:yyyy-MM-dd HH:mm}'}"
                                                Width="140" />
                        </DataGrid.Columns>
                    </DataGrid>
                </materialDesign:Card>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
