<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:dashboardVm="clr-namespace:HarnessHub.Dashboard.ViewModels;assembly=HarnessHub.Dashboard"
                    xmlns:dashboardView="clr-namespace:HarnessHub.Dashboard.Views;assembly=HarnessHub.Dashboard"
                    xmlns:explorerVm="clr-namespace:HarnessHub.Explorer.ViewModels;assembly=HarnessHub.Explorer"
                    xmlns:explorerView="clr-namespace:HarnessHub.Explorer.Views;assembly=HarnessHub.Explorer"
                    xmlns:editorVm="clr-namespace:HarnessHub.Editor.ViewModels;assembly=HarnessHub.Editor"
                    xmlns:editorView="clr-namespace:HarnessHub.Editor.Views;assembly=HarnessHub.Editor"
                    xmlns:presetVm="clr-namespace:HarnessHub.Preset.ViewModels;assembly=HarnessHub.Preset"
                    xmlns:presetView="clr-namespace:HarnessHub.Preset.Views;assembly=HarnessHub.Preset"
                    xmlns:settingVm="clr-namespace:HarnessHub.Setting.ViewModels;assembly=HarnessHub.Setting"
                    xmlns:settingView="clr-namespace:HarnessHub.Setting.Views;assembly=HarnessHub.Setting">

    <!-- Dashboard: ViewModel → View -->
    <DataTemplate DataType="{x:Type dashboardVm:DashboardViewModel}">
        <dashboardView:DashboardView />
    </DataTemplate>

    <!-- Explorer: ViewModel → View -->
    <DataTemplate DataType="{x:Type explorerVm:ExplorerViewModel}">
        <explorerView:ExplorerView />
    </DataTemplate>

    <!-- Editor: ViewModel → View -->
    <DataTemplate DataType="{x:Type editorVm:MarkdownEditorViewModel}">
        <editorView:MarkdownEditorView />
    </DataTemplate>

    <!-- Preset: ViewModel → View -->
    <DataTemplate DataType="{x:Type presetVm:PresetViewModel}">
        <presetView:PresetView />
    </DataTemplate>

    <!-- Setting: ViewModel → View -->
    <DataTemplate DataType="{x:Type settingVm:SettingViewModel}">
        <settingView:SettingView />
    </DataTemplate>

</ResourceDictionary>
