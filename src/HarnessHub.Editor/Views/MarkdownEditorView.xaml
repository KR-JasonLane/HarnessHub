<UserControl x:Class="HarnessHub.Editor.Views.MarkdownEditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:wpf="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
             xmlns:behaviors="clr-namespace:HarnessHub.Util.Behaviors;assembly=HarnessHub.Util"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="900">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- 상단 툴바 -->
        <materialDesign:Card Grid.Row="0" Padding="8 6" Margin="0 0 0 1">
            <DockPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Style="{StaticResource MaterialDesignFlatButton}"
                            Command="{Binding CloseFileCommand}"
                            Content="닫기"
                            Margin="4 0"
                            Visibility="{Binding IsFileOpen, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    <Button Style="{StaticResource MaterialDesignFlatButton}"
                            Command="{Binding SaveCommand}"
                            Content="저장"
                            Margin="4 0"
                            Visibility="{Binding IsFileOpen, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    <Button Style="{StaticResource MaterialDesignFlatButton}"
                            Command="{Binding RevertCommand}"
                            Content="되돌리기"
                            Margin="4 0"
                            Visibility="{Binding IsFileOpen, Converter={StaticResource BooleanToVisibilityConverter}}" />
                </StackPanel>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <materialDesign:PackIcon Kind="FileDocumentEdit"
                                             Width="20" Height="20"
                                             VerticalAlignment="Center"
                                             Margin="8 0 8 0"
                                             Foreground="{DynamicResource MaterialDesign.Brush.Primary}" />
                    <TextBlock Text="{Binding FileName}"
                               Style="{StaticResource MaterialDesignSubtitle1TextBlock}"
                               VerticalAlignment="Center" />
                    <TextBlock Text=" *"
                               VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource MaterialDesignSubtitle1TextBlock}">
                                <Setter Property="Foreground" Value="{DynamicResource MaterialDesign.Brush.Primary}" />
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsModified}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <TextBlock Margin="12 0 0 0"
                               VerticalAlignment="Center"
                               Opacity="0.6">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource MaterialDesignCaptionTextBlock}">
                                <Setter Property="Text" Value="{Binding FileType, StringFormat='({0})'}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding FileType}" Value="{x:Null}">
                                        <Setter Property="Text" Value="" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>
            </DockPanel>
        </materialDesign:Card>

        <!-- 중앙: 홈 패널 (파일 미선택 시) -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      Padding="8">
            <ScrollViewer.Style>
                <Style TargetType="ScrollViewer">
                    <Setter Property="Visibility" Value="Visible" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsFileOpen}" Value="True">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </ScrollViewer.Style>

            <StackPanel Margin="8">
                <!-- 기존 하네스 파일 목록 -->
                <TextBlock Text="하네스 파일"
                           Style="{StaticResource MaterialDesignHeadline6TextBlock}"
                           Margin="0 0 0 8" />

                <materialDesign:Card Padding="0" Margin="0 0 0 16">
                    <DataGrid ItemsSource="{Binding HarnessFiles}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              materialDesign:DataGridAssist.ColumnHeaderPadding="12 8"
                              materialDesign:DataGridAssist.CellPadding="12 8"
                              behaviors:DataGridDoubleClickBehavior.Command="{Binding SelectFileCommand}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="파일명"
                                                Binding="{Binding FileName}"
                                                Width="*" />
                            <DataGridTextColumn Header="범위"
                                                Binding="{Binding Scope}"
                                                Width="80" />
                            <DataGridTextColumn Header="레버"
                                                Binding="{Binding Lever}"
                                                Width="120" />
                            <DataGridTextColumn Header="토큰"
                                                Binding="{Binding TokenCount, StringFormat='{}{0:N0}'}"
                                                Width="80">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Right" />
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="수정일"
                                                Binding="{Binding LastModified, StringFormat='{}{0:yyyy-MM-dd HH:mm}'}"
                                                Width="140" />
                        </DataGrid.Columns>
                    </DataGrid>
                </materialDesign:Card>

                <!-- 생성 가능한 파일 목록 -->
                <TextBlock Text="새 하네스 파일 추가"
                           Style="{StaticResource MaterialDesignHeadline6TextBlock}"
                           Margin="0 8 0 8" />

                <ItemsControl ItemsSource="{Binding CreatableFiles}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Margin="4"
                                    Padding="12 8"
                                    Command="{Binding DataContext.CreateFileCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                    CommandParameter="{Binding}">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource MaterialDesignOutlinedButton}">
                                        <Setter Property="Height" Value="Auto" />
                                    </Style>
                                </Button.Style>
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="FilePlusOutline"
                                                             Width="18" Height="18"
                                                             VerticalAlignment="Center"
                                                             Margin="0 0 8 0" />
                                    <StackPanel>
                                        <TextBlock Text="{Binding RelativePath}"
                                                   Style="{StaticResource MaterialDesignBody2TextBlock}" />
                                        <TextBlock Opacity="0.6">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock" BasedOn="{StaticResource MaterialDesignCaptionTextBlock}">
                                                    <Setter Property="Text">
                                                        <Setter.Value>
                                                            <MultiBinding StringFormat="{}{0} · {1}">
                                                                <Binding Path="Scope" />
                                                                <Binding Path="Description" />
                                                            </MultiBinding>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                </StackPanel>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>

        <!-- 중앙: WebView2 에디터 (파일 선택 시) -->
        <wpf:WebView2 Grid.Row="1"
                       Visibility="{Binding IsFileOpen, Converter={StaticResource BooleanToVisibilityConverter}}"
                       behaviors:WebView2Behavior.WebViewFolder="{Binding WebViewFolder}"
                       behaviors:WebView2Behavior.MarkdownToLoad="{Binding MarkdownToLoad}"
                       behaviors:WebView2Behavior.EditedMarkdown="{Binding EditedMarkdown, Mode=TwoWay}"
                       behaviors:WebView2Behavior.LineCount="{Binding LineCount, Mode=TwoWay}"
                       behaviors:WebView2Behavior.RequestSave="{Binding RequestSave, Mode=TwoWay}"
                       behaviors:WebView2Behavior.Theme="{Binding EditorTheme}" />

        <!-- 하단 상태바 -->
        <Border Grid.Row="2"
                Background="{DynamicResource MaterialDesign.Brush.Card.Background}"
                Padding="12 4">
            <DockPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                            Visibility="{Binding IsFileOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <TextBlock Style="{StaticResource MaterialDesignCaptionTextBlock}"
                               Opacity="0.7"
                               Margin="16 0 0 0">
                        <Run Text="줄:" />
                        <Run Text="{Binding LineCount, StringFormat='{}{0:N0}', Mode=OneWay}" />
                    </TextBlock>
                    <TextBlock Style="{StaticResource MaterialDesignCaptionTextBlock}"
                               Opacity="0.7"
                               Margin="16 0 0 0">
                        <Run Text="토큰:" />
                        <Run Text="{Binding TokenCount, StringFormat='{}{0:N0}', Mode=OneWay}" />
                    </TextBlock>
                </StackPanel>

                <TextBlock Style="{StaticResource MaterialDesignCaptionTextBlock}"
                           Opacity="0.7"
                           TextTrimming="CharacterEllipsis"
                           VerticalAlignment="Center">
                    <TextBlock.Text>
                        <Binding Path="FilePath" TargetNullValue="편집할 파일을 선택하거나, 새 하네스 파일을 추가하세요" />
                    </TextBlock.Text>
                </TextBlock>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
