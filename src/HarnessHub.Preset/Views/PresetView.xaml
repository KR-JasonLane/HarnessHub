<UserControl x:Class="HarnessHub.Preset.Views.PresetView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:converters="clr-namespace:HarnessHub.Util.Converters;assembly=HarnessHub.Util"
             xmlns:harness="clr-namespace:HarnessHub.Models.Harness;assembly=HarnessHub.Models"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="900">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <converters:EnumToVisibilityConverter x:Key="EnumToVisibilityConverter" />
        <converters:EnumToBoolConverter x:Key="EnumToBoolConverter" />
    </UserControl.Resources>

    <Grid>
        <!-- 로딩 인디케이터 -->
        <ProgressBar Style="{StaticResource MaterialDesignLinearProgressBar}"
                     IsIndeterminate="True"
                     VerticalAlignment="Top"
                     Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}" />

        <!-- ===== List 모드 ===== -->
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      Padding="8"
                      Visibility="{Binding ViewState, Converter={StaticResource EnumToVisibilityConverter}, ConverterParameter=List}">
            <StackPanel Margin="8">

                <!-- 상단 액션 바 -->
                <DockPanel Margin="0 0 0 16">
                    <TextBlock DockPanel.Dock="Left"
                               Text="프리셋 관리"
                               Style="{StaticResource MaterialDesignHeadline5TextBlock}"
                               VerticalAlignment="Center" />

                    <StackPanel DockPanel.Dock="Right"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right">
                        <Button Style="{StaticResource MaterialDesignOutlinedButton}"
                                Command="{Binding ImportPresetCommand}"
                                Content="가져오기"
                                Margin="0 0 8 0" />

                        <Button Style="{StaticResource MaterialDesignRaisedButton}"
                                Command="{Binding NewPresetCommand}">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Plus" VerticalAlignment="Center" Margin="0 0 4 0" />
                                <TextBlock Text="새 프리셋" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </DockPanel>

                <!-- 글로벌 프리셋 섹션 -->
                <DockPanel Margin="0 0 0 8">
                    <TextBlock DockPanel.Dock="Left"
                               Text="글로벌 프리셋"
                               Style="{StaticResource MaterialDesignHeadline6TextBlock}"
                               VerticalAlignment="Center" />
                    <Button DockPanel.Dock="Right"
                            Style="{StaticResource MaterialDesignOutlinedButton}"
                            Command="{Binding CaptureCurrentCommand}"
                            CommandParameter="{x:Static harness:HarnessScope.Global}"
                            Content="현재 캡처"
                            HorizontalAlignment="Right" />
                </DockPanel>

                <ItemsControl ItemsSource="{Binding GlobalPresets}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <materialDesign:Card Padding="16" Margin="0 0 0 8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <!-- 활성 표시 아이콘 -->
                                    <materialDesign:PackIcon Grid.Column="0"
                                                             Kind="CheckCircle"
                                                             Width="24" Height="24"
                                                             VerticalAlignment="Center"
                                                             Margin="0 0 12 0"
                                                             Foreground="{DynamicResource MaterialDesign.Brush.Primary}">
                                        <materialDesign:PackIcon.Style>
                                            <Style TargetType="materialDesign:PackIcon">
                                                <Setter Property="Visibility" Value="Hidden" />
                                                <Style.Triggers>
                                                    <DataTrigger Value="True">
                                                        <DataTrigger.Binding>
                                                            <MultiBinding StringFormat="{}{0}">
                                                                <Binding Path="Name" />
                                                            </MultiBinding>
                                                        </DataTrigger.Binding>
                                                        <Setter Property="Visibility" Value="Hidden" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </materialDesign:PackIcon.Style>
                                    </materialDesign:PackIcon>

                                    <!-- 프리셋 정보 -->
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Name}"
                                                   Style="{StaticResource MaterialDesignSubtitle1TextBlock}" />
                                        <TextBlock Text="{Binding Description}"
                                                   Style="{StaticResource MaterialDesignCaptionTextBlock}"
                                                   Opacity="0.7"
                                                   Margin="0 2 0 0"
                                                   TextTrimming="CharacterEllipsis" />
                                        <StackPanel Orientation="Horizontal" Margin="0 4 0 0">
                                            <TextBlock Style="{StaticResource MaterialDesignCaptionTextBlock}"
                                                       Opacity="0.6">
                                                <Run Text="{Binding TotalTokens, StringFormat='{}{0:N0} tok', Mode=OneWay}" />
                                                <Run Text=" | " />
                                                <Run Text="{Binding Files.Count, StringFormat='{}{0}개 파일', Mode=OneWay}" />
                                            </TextBlock>
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- 액션 버튼 -->
                                    <StackPanel Grid.Column="2"
                                                Orientation="Horizontal"
                                                VerticalAlignment="Center">
                                        <Button Style="{StaticResource MaterialDesignFlatButton}"
                                                Command="{Binding DataContext.ApplyPresetCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}"
                                                Content="적용"
                                                Margin="0 0 4 0" />
                                        <Button Style="{StaticResource MaterialDesignIconButton}"
                                                Command="{Binding DataContext.EditPresetCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}"
                                                ToolTip="편집">
                                            <materialDesign:PackIcon Kind="Pencil" />
                                        </Button>
                                        <Button Style="{StaticResource MaterialDesignIconButton}"
                                                Command="{Binding DataContext.ExportPresetCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}"
                                                ToolTip="내보내기">
                                            <materialDesign:PackIcon Kind="Export" />
                                        </Button>
                                        <Button Style="{StaticResource MaterialDesignIconButton}"
                                                Command="{Binding DataContext.DeletePresetCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}"
                                                ToolTip="삭제">
                                            <materialDesign:PackIcon Kind="Delete" />
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </materialDesign:Card>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- 글로벌 프리셋 없을 때 -->
                <TextBlock Text="글로벌 프리셋이 없습니다. '현재 캡처' 또는 '새 프리셋'으로 생성하세요."
                           Opacity="0.5"
                           Margin="16 8"
                           HorizontalAlignment="Center">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock" BasedOn="{StaticResource MaterialDesignBody2TextBlock}">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding GlobalPresets.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <!-- 프로젝트 프리셋 섹션 -->
                <DockPanel Margin="0 16 0 8">
                    <TextBlock DockPanel.Dock="Left"
                               Text="프로젝트 프리셋"
                               Style="{StaticResource MaterialDesignHeadline6TextBlock}"
                               VerticalAlignment="Center" />
                    <Button DockPanel.Dock="Right"
                            Style="{StaticResource MaterialDesignOutlinedButton}"
                            Command="{Binding CaptureCurrentCommand}"
                            CommandParameter="{x:Static harness:HarnessScope.Project}"
                            Content="현재 캡처"
                            HorizontalAlignment="Right" />
                </DockPanel>

                <ItemsControl ItemsSource="{Binding ProjectPresets}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <materialDesign:Card Padding="16" Margin="0 0 0 8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <materialDesign:PackIcon Grid.Column="0"
                                                             Kind="CheckCircle"
                                                             Width="24" Height="24"
                                                             VerticalAlignment="Center"
                                                             Margin="0 0 12 0"
                                                             Foreground="{DynamicResource MaterialDesign.Brush.Primary}"
                                                             Visibility="Hidden" />

                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Name}"
                                                   Style="{StaticResource MaterialDesignSubtitle1TextBlock}" />
                                        <TextBlock Text="{Binding Description}"
                                                   Style="{StaticResource MaterialDesignCaptionTextBlock}"
                                                   Opacity="0.7"
                                                   Margin="0 2 0 0"
                                                   TextTrimming="CharacterEllipsis" />
                                        <StackPanel Orientation="Horizontal" Margin="0 4 0 0">
                                            <TextBlock Style="{StaticResource MaterialDesignCaptionTextBlock}"
                                                       Opacity="0.6">
                                                <Run Text="{Binding TotalTokens, StringFormat='{}{0:N0} tok', Mode=OneWay}" />
                                                <Run Text=" | " />
                                                <Run Text="{Binding Files.Count, StringFormat='{}{0}개 파일', Mode=OneWay}" />
                                            </TextBlock>
                                        </StackPanel>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2"
                                                Orientation="Horizontal"
                                                VerticalAlignment="Center">
                                        <Button Style="{StaticResource MaterialDesignFlatButton}"
                                                Command="{Binding DataContext.ApplyPresetCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}"
                                                Content="적용"
                                                Margin="0 0 4 0" />
                                        <Button Style="{StaticResource MaterialDesignIconButton}"
                                                Command="{Binding DataContext.EditPresetCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}"
                                                ToolTip="편집">
                                            <materialDesign:PackIcon Kind="Pencil" />
                                        </Button>
                                        <Button Style="{StaticResource MaterialDesignIconButton}"
                                                Command="{Binding DataContext.ExportPresetCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}"
                                                ToolTip="내보내기">
                                            <materialDesign:PackIcon Kind="Export" />
                                        </Button>
                                        <Button Style="{StaticResource MaterialDesignIconButton}"
                                                Command="{Binding DataContext.DeletePresetCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}"
                                                ToolTip="삭제">
                                            <materialDesign:PackIcon Kind="Delete" />
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </materialDesign:Card>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- 프로젝트 프리셋 없을 때 -->
                <TextBlock Opacity="0.5"
                           Margin="16 8"
                           HorizontalAlignment="Center">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock" BasedOn="{StaticResource MaterialDesignBody2TextBlock}">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Setter Property="Text" Value="프로젝트 프리셋이 없습니다." />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ProjectPresets.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <!-- 토큰 합계 바 -->
                <materialDesign:Card Padding="16" Margin="0 16 0 0">
                    <StackPanel>
                        <TextBlock Text="활성 프리셋 조합 토큰"
                                   Style="{StaticResource MaterialDesignSubtitle2TextBlock}"
                                   Margin="0 0 0 8" />
                        <DockPanel Margin="0 0 0 8">
                            <TextBlock DockPanel.Dock="Right"
                                       Style="{StaticResource MaterialDesignBody2TextBlock}">
                                <Run Text="{Binding CombinedTotalTokens, StringFormat='{}{0:N0}', Mode=OneWay}" />
                                <Run Text=" / " />
                                <Run Text="{Binding ContextWindowSize, StringFormat='{}{0:N0}', Mode=OneWay}" />
                                <Run Text=" tok" />
                            </TextBlock>
                            <TextBlock Text="{Binding CombinedUsagePercentage, StringFormat='{}{0:F1}%'}"
                                       Style="{StaticResource MaterialDesignBody2TextBlock}"
                                       Foreground="{DynamicResource MaterialDesign.Brush.Primary}" />
                        </DockPanel>
                        <ProgressBar Style="{StaticResource MaterialDesignLinearProgressBar}"
                                     Minimum="0" Maximum="100"
                                     Value="{Binding CombinedUsagePercentage, Mode=OneWay}"
                                     Height="8" />
                    </StackPanel>
                </materialDesign:Card>

            </StackPanel>
        </ScrollViewer>

        <!-- ===== Editor 모드 ===== -->
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      Padding="8"
                      Visibility="{Binding ViewState, Converter={StaticResource EnumToVisibilityConverter}, ConverterParameter=Editor}">
            <StackPanel Margin="8">

                <!-- 에디터 헤더 -->
                <DockPanel Margin="0 0 0 16">
                    <TextBlock DockPanel.Dock="Left"
                               VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource MaterialDesignHeadline5TextBlock}">
                                <Setter Property="Text" Value="새 프리셋" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                        <Setter Property="Text" Value="프리셋 편집" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <StackPanel DockPanel.Dock="Right"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right">
                        <Button Style="{StaticResource MaterialDesignOutlinedButton}"
                                Command="{Binding CancelEditCommand}"
                                Content="취소"
                                Margin="0 0 8 0" />
                        <Button Style="{StaticResource MaterialDesignRaisedButton}"
                                Command="{Binding SavePresetCommand}"
                                Content="저장" />
                    </StackPanel>
                </DockPanel>

                <!-- 기본 정보 -->
                <materialDesign:Card Padding="16" Margin="0 0 0 16">
                    <StackPanel>
                        <TextBox materialDesign:HintAssist.Hint="프리셋 이름"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 Text="{Binding EditorName, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0 0 0 12" />

                        <TextBox materialDesign:HintAssist.Hint="설명"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 Text="{Binding EditorDescription, UpdateSourceTrigger=PropertyChanged}"
                                 TextWrapping="Wrap"
                                 MinLines="2"
                                 MaxLines="4"
                                 Margin="0 0 0 12" />

                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="범위: "
                                       Style="{StaticResource MaterialDesignBody1TextBlock}"
                                       VerticalAlignment="Center"
                                       Margin="0 0 8 0" />
                            <RadioButton Content="글로벌"
                                         GroupName="Scope"
                                         IsChecked="{Binding EditorScope, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Global}"
                                         Margin="0 0 16 0" />
                            <RadioButton Content="프로젝트"
                                         GroupName="Scope"
                                         IsChecked="{Binding EditorScope, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Project}" />
                        </StackPanel>
                    </StackPanel>
                </materialDesign:Card>

                <!-- 파일 목록 -->
                <TextBlock Text="포함 파일"
                           Style="{StaticResource MaterialDesignHeadline6TextBlock}"
                           Margin="0 0 0 8" />

                <materialDesign:Card Padding="0">
                    <DataGrid ItemsSource="{Binding EditorFiles}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              materialDesign:DataGridAssist.ColumnHeaderPadding="12 8"
                              materialDesign:DataGridAssist.CellPadding="12 8">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="경로"
                                                Binding="{Binding RelativePath}"
                                                Width="*" />
                            <DataGridTextColumn Header="유형"
                                                Binding="{Binding FileType}"
                                                Width="140" />
                            <DataGridTextColumn Header="토큰"
                                                Binding="{Binding TokenCount, StringFormat='{}{0:N0}'}"
                                                Width="80">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Right" />
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </materialDesign:Card>

                <!-- 토큰 합계 -->
                <materialDesign:Card Padding="16" Margin="0 16 0 0">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Left"
                                   Text="합계"
                                   Style="{StaticResource MaterialDesignSubtitle2TextBlock}"
                                   VerticalAlignment="Center" />
                        <TextBlock DockPanel.Dock="Right"
                                   HorizontalAlignment="Right"
                                   Style="{StaticResource MaterialDesignBody1TextBlock}"
                                   Foreground="{DynamicResource MaterialDesign.Brush.Primary}">
                            <Run Text="{Binding EditorTotalTokens, StringFormat='{}{0:N0}', Mode=OneWay}" />
                            <Run Text=" tok" />
                        </TextBlock>
                    </DockPanel>
                </materialDesign:Card>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
